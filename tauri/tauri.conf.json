{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-v2/refs/heads/core/tooling/cli/schema.json",
  "productName": "BswMViewer",
  "version": "1.0.0",
  "identifier": "com.bswmviewer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BswM Viewer",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {}
  },
  "plugins": {
    "dialog": null
  }
}
